---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import LandingPage from "../components/LandingPage.tsx";

const site = "https://mdburst.com";
const title = "mdburst — Write once in markdown. Publish everywhere.";
const description =
  "mdburst converts one markdown draft into platform-ready blog posts, newsletters, LinkedIn posts, and social threads — with formatting that survives the trip.";
---
<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={site} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="mdburst — Write once. Publish everywhere." />
    <meta
      property="og:description"
      content="Turn one markdown draft into publish-ready posts for Ghost, newsletters, LinkedIn, and social threads."
    />
    <meta property="og:url" content={site} />
    <meta property="og:site_name" content="mdburst.com" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="mdburst — Write once. Publish everywhere." />
    <meta
      name="twitter:description"
      content="Turn one markdown draft into publish-ready posts for Ghost, newsletters, LinkedIn, and social threads."
    />

    <!-- JSON-LD structured data: Organization + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://mdburst.com/#organization",
          "name": "mdburst.com",
          "url": "https://mdburst.com/"
        },
        {
          "@type": "WebSite",
          "@id": "https://mdburst.com/#website",
          "url": "https://mdburst.com/",
          "name": "mdburst.com",
          "publisher": { "@id": "https://mdburst.com/#organization" }
        }
      ]
    })} />
  </Fragment>

  <LandingPage client:load />
</Layout>
